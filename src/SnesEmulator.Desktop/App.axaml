<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SnesEmulator.Desktop.App"
             xmlns:local="using:SnesEmulator.Desktop"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- SNES-inspired color palette -->
        <Color x:Key="SnesBackground">#1A1A2E</Color>
        <Color x:Key="SnesPrimary">#16213E</Color>
        <Color x:Key="SnesAccent">#E94560</Color>
        <Color x:Key="SnesAccentDim">#8B2635</Color>
        <Color x:Key="SnesGray">#4A4A6A</Color>
        <Color x:Key="SnesText">#E8E8F0</Color>
        <Color x:Key="SnesTextDim">#9090A8</Color>
        <Color x:Key="SnesSuccess">#4CAF82</Color>
        <Color x:Key="SnesWarning">#FFB347</Color>
        <Color x:Key="SnesError">#E94560</Color>
        <Color x:Key="SnesBorder">#2A2A4A</Color>
        <Color x:Key="SnesPanel">#0F0F1A</Color>

        <SolidColorBrush x:Key="BackgroundBrush"  Color="{StaticResource SnesBackground}"/>
        <SolidColorBrush x:Key="PrimaryBrush"     Color="{StaticResource SnesPrimary}"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource SnesAccent}"/>
        <SolidColorBrush x:Key="AccentDimBrush"   Color="{StaticResource SnesAccentDim}"/>
        <SolidColorBrush x:Key="GrayBrush"        Color="{StaticResource SnesGray}"/>
        <SolidColorBrush x:Key="TextBrush"        Color="{StaticResource SnesText}"/>
        <SolidColorBrush x:Key="TextDimBrush"     Color="{StaticResource SnesTextDim}"/>
        <SolidColorBrush x:Key="SuccessBrush"     Color="{StaticResource SnesSuccess}"/>
        <SolidColorBrush x:Key="WarningBrush"     Color="{StaticResource SnesWarning}"/>
        <SolidColorBrush x:Key="ErrorBrush"       Color="{StaticResource SnesError}"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="{StaticResource SnesBorder}"/>
        <SolidColorBrush x:Key="PanelBrush"       Color="{StaticResource SnesPanel}"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI, Arial, sans-serif"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Background"  Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="12,6"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource GrayBrush}"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>

        <Style Selector="Border.panel">
            <Setter Property="Background"       Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="6"/>
            <Setter Property="Padding"          Value="8"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background"  Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="FontFamily"  Value="Cascadia Code, Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>
    </Application.Styles>
</Application>
